# ASI:One LLM API key (Orchestrator reasoning). Leave blank when USE_MOCK=true.
ASIONE_API_KEY=YOUR_API_KEY_HERE

# Redis connection. Leave blank to use the in-memory store (no Redis needed).
REDIS_URL=

# fal.ai key for Pika video replay (stretch only). Leave blank if unused.
FAL_KEY=

# Base seed for deterministic agent address derivation.
AGENT_SEED=er-twin-demo-seed

# When true, the Orchestrator returns hardcoded responses instead of calling ASI:One.
USE_MOCK=true

# --- Dashboard (Dev 3) ---
# Data source: "fixture" (default, no Redis) or "redis" (live, needs REDIS_URL).
DASHBOARD_SOURCE=fixture
# Allow the dashboard to send commands to the Orchestrator (read-only baseline = false).
DASHBOARD_ALLOW_INPUT=false
DASHBOARD_PORT=8050
# Login gate (demo only — NOT real HIPAA). Change these for anything beyond a demo.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=password
DASHBOARD_SECRET_KEY=dev-insecure-secret-change-me
# Google sign-in (optional). Create an OAuth 2.0 Client (Web) in Google Cloud Console,
# add redirect URIs http://localhost:8050/auth/callback and
# http://127.0.0.1:8050/auth/callback, and paste the values here.
# If using a personal Gmail, the OAuth app must be External and your account must be a
# test user unless the consent screen is published. When set, a "Sign in with Google"
# button appears; ANY authenticated Google account is accepted by the app (no allowlist).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
